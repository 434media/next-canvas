# pnpm config — pins package manager and enables strict mode.
# Corepack reads `packageManager` in package.json (`pnpm@10.4.1`) and refuses
# to run npm/yarn against this project. This file adds defense in depth for
# environments where Corepack isn't enabled.

# Fail if a transitive dep declares an engines.node range that the local
# Node doesn't satisfy. Catches Node-version drift early.
engine-strict=true

# Stricter peer-dep handling — surfaces missing peers rather than silently
# auto-installing them. Matches pnpm's recommended posture for apps.
auto-install-peers=false
strict-peer-dependencies=false
